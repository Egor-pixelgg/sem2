#include <iostream>
#include <vector>
#include <fstream>
#include <cstring> 

using namespace std;

#pragma pack(push, 1)
struct FileHeader
{
    char signature[4];  
    int version; 
    int studentCount;
};
#pragma pack(pop)
const char expectedSignature[4] = {'G','R','D','1'};

void inputGrades(vector<vector<double>>& grades)
{
    for (int i = 0; i < grades.size(); i++)
    {
        cout << "\nСтудент " << i + 1 << ":\n";
        for (int j = 0; j < grades[i].size(); j++)
        {
            double value;

            while (true)
            {
                cout << "  Оценка по предмету " << j + 1 << " (0-5): ";
                cin >> value;

                if (value < 0.0 || value > 5.0)
                {
                    cout << "Ошибка ввода. Повторите.\n";
                }
                else
                {
                    grades[i][j] = value;
                    break;
                }
            }
        }
    }
}

void saveToFile(const string& filename,
                const vector<vector<double>>& grades)
{
    ofstream out(filename, ios::binary);

    if (!out)
    {
        cout << "Ошибка открытия файла для записи\n";
        return;
    }

    FileHeader header;
    // Исправлено: копирование сигнатуры
    memcpy(header.signature, expectedSignature, 4);
    header.version = 1;
    header.studentCount = grades.size();
    cout << "\nРазмер структуры заголовка: "
         << sizeof(FileHeader) << " байт (с #pragma pack(1))\n";
    cout << "Обычный размер был бы: " << sizeof(char[4]) + sizeof(int) + sizeof(int) 
         << " (без выравнивания)\n";
    out.write(reinterpret_cast<char*>(&header), sizeof(header));
    int subjectCount = grades[0].size();
    out.write(reinterpret_cast<char*>(&subjectCount), sizeof(subjectCount));
    for (const auto& student : grades)
    {
        out.write(reinterpret_cast<const char*>(student.data()),
                  subjectCount * sizeof(double));
    }

    out.close();
    cout << "Данные успешно сохранены в файл: " << filename << "\n";
}

void loadFromFile(const string& filename)
{
    ifstream in(filename, ios::binary);

    if (!in)
    {
        cout << "Ошибка открытия файла для чтения\n";
        return;
    }

    FileHeader header;
    in.read(reinterpret_cast<char*>(&header), sizeof(header));

    // Требование 6: Проверить корректность сигнатуры
    if (memcmp(header.signature, expectedSignature, 4) != 0)
    {
        cout << "Ошибка: неверная сигнатура файла\n";
        cout << "Ожидалось: ";
        for (int i = 0; i < 4; i++) cout << expectedSignature[i];
        cout << "\nПолучено: ";
        for (int i = 0; i < 4; i++) cout << header.signature[i];
        cout << "\n";
        in.close();
        return;
    }

    int subjectCount;
    in.read(reinterpret_cast<char*>(&subjectCount), sizeof(subjectCount));

    // Проверка на успешное чтение
    if (in.fail())
    {
        cout << "Ошибка чтения количества предметов\n";
        in.close();
        return;
    }

    vector<vector<double>> grades(header.studentCount,
                                  vector<double>(subjectCount));

    for (int i = 0; i < header.studentCount; i++)
    {
        in.read(reinterpret_cast<char*>(grades[i].data()),
                subjectCount * sizeof(double));
        
        if (in.fail())
        {
            cout << "Ошибка чтения оценок студента " << i + 1 << "\n";
            in.close();
            return;
        }
    }

    cout << "\nДанные успешно загружены из файла: " << filename << "\n";
    cout << "Версия файла: " << header.version << "\n";
    cout << "Количество студентов: " << header.studentCount << "\n";
    cout << "Количество предметов: " << subjectCount << "\n";
cout << "\nОценки:\n";
    for (int i = 0; i < grades.size(); i++)
    {
        cout << "Студент " << i + 1 << ": ";
        for (double g : grades[i])
            cout << g << " ";
        cout << "\n";
    }

    in.close();
}

int main()
{
    int N, M;

    cout << "Введите количество студентов: ";
    cin >> N;

    cout << "Введите количество предметов: ";
    cin >> M;

    if (N <= 0 || M <= 0)
    {
        cout << "Ошибка: значения должны быть натуральными\n";
        return 1;
    }
    vector<vector<double>> grades(N, vector<double>(M));
    inputGrades(grades);
    string filename = "grades.bin";
    saveToFile(filename, grades);
    loadFromFile(filename);

    return 0;
}
